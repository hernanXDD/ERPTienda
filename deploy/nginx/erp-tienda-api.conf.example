# Reverse proxy HTTPS → API Node (PM2 en 127.0.0.1:3000)
# VPS: 200.58.99.253 — vps-6055529-x.dattaweb.com
#
# Copiar a /etc/nginx/sites-available/erp-tienda-api
# sudo ln -s /etc/nginx/sites-available/erp-tienda-api /etc/nginx/sites-enabled/
# sudo certbot --nginx -d vps-6055529-x.dattaweb.com

server {
    listen 80;
    server_name vps-6055529-x.dattaweb.com;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name vps-6055529-x.dattaweb.com;

    ssl_certificate     /etc/letsencrypt/live/vps-6055529-x.dattaweb.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/vps-6055529-x.dattaweb.com/privkey.pem;

    client_max_body_size 10m;

    location / {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 60s;
    }
}
