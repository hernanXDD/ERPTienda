# Copiar al VPS:
#   sudo cp deploy/fail2ban/jail.local.example /etc/fail2ban/jail.local
#   sudo systemctl restart fail2ban
#   sudo fail2ban-client status sshd

[DEFAULT]
bantime  = 1h
findtime = 10m
maxretry = 5
banaction = ufw

[sshd]
enabled = true
port    = ssh
filter  = sshd
logpath = /var/log/auth.log
maxretry = 4
