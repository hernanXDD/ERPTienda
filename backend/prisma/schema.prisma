// ERP Tienda — esquema inicial (3FN, tablas en singular)
// Alineado con tipos del frontend Vue (mocks → API real)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// —— Enums ——

enum RolUsuario {
  ADMIN
  DUENO
  EMPLEADO

  @@map("rol_usuario")
}

enum CondicionCompra {
  CONTADO
  CUENTA_PROVEEDOR

  @@map("condicion_compra")
}

enum CondicionIvaCliente {
  CONSUMIDOR_FINAL
  RESPONSABLE_INSCRIPTO
  MONOTRIBUTO
  EXENTO
  NO_RESPONSABLE

  @@map("condicion_iva_cliente")
}

enum TipoMovimientoCuentaCorriente {
  cargo
  pagoRegistrado

  @@map("tipo_movimiento_cuenta_corriente")
}

enum TipoAuditoriaStock {
  venta
  compra
  conteo
  devolucion

  @@map("tipo_auditoria_stock")
}

enum EstadoCuponDescuento {
  activo
  usado
  anulado

  @@map("estado_cupon_descuento")
}

enum TipoDescuentoCupon {
  porcentaje
  monto_fijo

  @@map("tipo_descuento_cupon")
}

// —— Usuarios y seguridad ——

model Usuario {
  id                       String     @id @db.Char(6)
  nombre                   String     @db.VarChar(64)
  apellido                 String     @db.VarChar(64)
  nombreUsuario            String     @map("nombre_usuario") @db.VarChar(64)
  contrasenaHash           String     @map("contrasena_hash") @db.VarChar(255) /// Hash bcrypt; nunca almacenar texto plano
  contrasenaEstaBlanqueada Boolean    @default(false) @map("contrasena_esta_blanqueada")
  debeCambiarContrasena    Boolean    @default(true) @map("debe_cambiar_contrasena")
  modoOscuroHabilitado     Boolean    @default(true) @map("modo_oscuro_habilitado")
  rol                      RolUsuario
  habilitado               Boolean    @default(true)
  /// Permisos operativos + menús visibles (JSON, mismo shape que frontend)
  permisosJson             Json       @map("permisos_json")
  fechaCreacion            DateTime   @default(now()) @map("fecha_creacion") @db.Timestamptz(3)
  fechaActualizacion       DateTime   @updatedAt @map("fecha_actualizacion") @db.Timestamptz(3)
  borrado                  Boolean    @default(false)
  fechaEliminacion         DateTime?  @map("fecha_eliminacion") @db.Timestamptz(3)

  movimientosStock           MovimientoStock[]
  movimientosCuentaCorriente MovimientoCuentaCorriente[] @relation("MovimientoCcRegistradoPor")
  movimientosCuentaCorrienteProveedor MovimientoCuentaCorrienteProveedor[] @relation("MovimientoCcProveedorRegistradoPor")
  auditoriasStock            AuditoriaStock[]
  devolucionesRegistradas  Devolucion[]                @relation("DevolucionRegistradaPor")
  cuponesDescuentoRegistrados CuponDescuento[]         @relation("CuponDescuentoRegistradoPor")

  @@index([habilitado])
  @@index([rol])
  @@index([nombreUsuario])
  @@index([borrado])
  @@map("usuario")
}

// —— Catálogo ——

model Categoria {
  id                 String    @id @db.Char(6)
  nombre             String    @db.VarChar(120)
  descripcion        String    @default("") @db.VarChar(500)
  fechaCreacion      DateTime  @default(now()) @map("fecha_creacion") @db.Timestamptz(3)
  fechaActualizacion DateTime  @updatedAt @map("fecha_actualizacion") @db.Timestamptz(3)
  borrado            Boolean   @default(false)
  fechaEliminacion   DateTime? @map("fecha_eliminacion") @db.Timestamptz(3)

  productos Producto[]

  @@index([nombre])
  @@index([borrado])
  @@map("categoria")
}

enum TipoTalleCatalogo {
  LETRA
  NUMERO
  OTRO
}

model TalleCatalogo {
  id                 String            @id @db.Char(6)
  codigo             String            @unique @db.VarChar(32)
  nombre             String            @db.VarChar(100)
  tipo               TipoTalleCatalogo @default(OTRO)
  habilitado         Boolean           @default(true)
  orden              Int               @default(0)
  fechaCreacion      DateTime          @default(now()) @map("fecha_creacion") @db.Timestamptz(3)
  fechaActualizacion DateTime          @updatedAt @map("fecha_actualizacion") @db.Timestamptz(3)
  borrado            Boolean           @default(false)
  fechaEliminacion   DateTime?         @map("fecha_eliminacion") @db.Timestamptz(3)

  @@index([habilitado, orden])
  @@index([tipo, habilitado, orden])
  @@index([borrado])
  @@map("talle_catalogo")
}

model Producto {
  id                 String    @id @db.Char(6)
  nombre             String    @db.VarChar(200)
  marca              String    @db.VarChar(120)
  descripcion        String    @default("") @db.VarChar(1000)
  categoriaId        String    @map("categoria_id") @db.Char(6)
  precioVenta        Decimal   @map("precio_venta") @db.Decimal(14, 2)
  fechaCreacion      DateTime  @default(now()) @map("fecha_creacion") @db.Timestamptz(3)
  fechaActualizacion DateTime  @updatedAt @map("fecha_actualizacion") @db.Timestamptz(3)
  borrado            Boolean   @default(false)
  fechaEliminacion   DateTime? @map("fecha_eliminacion") @db.Timestamptz(3)

  categoria Categoria  @relation(fields: [categoriaId], references: [id], onDelete: Restrict)
  variantes Variante[]

  @@index([categoriaId])
  @@index([nombre])
  @@index([borrado])
  @@map("producto")
}

model Variante {
  id                 String   @id @db.Char(6)
  productoId         String   @map("producto_id") @db.Char(6)
  talle              String   @db.VarChar(32)
  color              String   @db.VarChar(64)
  codigoBarras       String   @default("") @map("codigo_barras") @db.VarChar(64)
  activa             Boolean   @default(true)
  fechaCreacion      DateTime  @default(now()) @map("fecha_creacion") @db.Timestamptz(3)
  fechaActualizacion DateTime  @updatedAt @map("fecha_actualizacion") @db.Timestamptz(3)
  borrado            Boolean   @default(false)
  fechaEliminacion   DateTime? @map("fecha_eliminacion") @db.Timestamptz(3)

  producto         Producto          @relation(fields: [productoId], references: [id], onDelete: Cascade)
  stock            StockVariante?
  movimientosStock MovimientoStock[]
  lineasVenta      VentaLinea[]
  lineasCompra     CompraLinea[]

  @@index([productoId, talle, color])
  @@index([codigoBarras])
  @@index([activa])
  @@index([borrado])
  @@map("variante")
}

/// Saldo vigente por variante (una fila por SKU)
model StockVariante {
  varianteId         String    @id @map("variante_id") @db.Char(6)
  cantidadActual     Int       @default(0) @map("cantidad_actual")
  fechaAgotado       DateTime? @map("fecha_agotado") @db.Timestamptz(3)
  fechaActualizacion DateTime  @updatedAt @map("fecha_actualizacion") @db.Timestamptz(3)

  variante Variante @relation(fields: [varianteId], references: [id], onDelete: Cascade)

  @@map("stock_variante")
}

/// Agrupación de movimientos de stock (venta, compra o conteo físico).
model AuditoriaStock {
  id                    String             @id @db.Char(6)
  tipo                  TipoAuditoriaStock
  fecha                 DateTime           @default(now()) @db.Timestamptz(3)
  titulo                String             @db.VarChar(255)
  referencia            String?            @db.VarChar(32)
  nota                  String?            @db.VarChar(500)
  variacionNeta         Int                @default(0) @map("variacion_neta")
  cantidadMovimientos   Int                @default(0) @map("cantidad_movimientos")
  ventaId               String?            @map("venta_id") @db.Char(6)
  compraId              String?            @map("compra_id") @db.Char(6)
  devolucionId          String?            @map("devolucion_id") @db.Char(6)
  ejecutadoPorUsuarioId String?            @map("ejecutado_por_usuario_id") @db.Char(6)
  fechaCreacion         DateTime           @default(now()) @map("fecha_creacion") @db.Timestamptz(3)

  venta               Venta?            @relation(fields: [ventaId], references: [id], onDelete: SetNull)
  compra              Compra?           @relation(fields: [compraId], references: [id], onDelete: SetNull)
  devolucion          Devolucion?       @relation(fields: [devolucionId], references: [id], onDelete: SetNull)
  ejecutadoPorUsuario Usuario?          @relation(fields: [ejecutadoPorUsuarioId], references: [id], onDelete: SetNull)
  movimientos         MovimientoStock[]

  @@index([fecha(sort: Desc)])
  @@index([tipo])
  @@index([ventaId])
  @@index([compraId])
  @@index([devolucionId])
  @@map("auditoria_stock")
}

/// Catálogo de motivos para movimientos de stock.
model Motivo {
  id                 String   @id @db.Char(6)
  nombre             String   @db.VarChar(120)
  descripcion        String   @default("") @db.VarChar(500)
  activo             Boolean  @default(true)
  fechaCreacion      DateTime @default(now()) @map("fecha_creacion") @db.Timestamptz(3)
  fechaActualizacion DateTime @updatedAt @map("fecha_actualizacion") @db.Timestamptz(3)

  movimientosStock MovimientoStock[]

  @@index([activo])
  @@map("motivo")
}

model MovimientoStock {
  id                    String                @id @db.Char(6)
  fecha                 DateTime              @default(now()) @db.Timestamptz(3)
  varianteId            String                @map("variante_id") @db.Char(6)
  nombreVariante        String                @map("nombre_variante") @db.VarChar(255)
  motivoId              String                @map("motivo_id") @db.Char(6)
  cantidadVariacion     Int                   @map("cantidad_variacion")
  stockResultante       Int                   @map("stock_resultante")
  ventaId               String?               @map("venta_id") @db.Char(6)
  numeroVenta           String?               @map("numero_venta") @db.VarChar(32)
  compraId              String?               @map("compra_id") @db.Char(6)
  auditoriaStockId      String?               @map("auditoria_stock_id") @db.Char(6)
  nota                  String?               @db.VarChar(500)
  ejecutadoPorUsuarioId String?               @map("ejecutado_por_usuario_id") @db.Char(6)
  fechaCreacion         DateTime              @default(now()) @map("fecha_creacion") @db.Timestamptz(3)

  variante            Variante        @relation(fields: [varianteId], references: [id], onDelete: Restrict)
  motivo              Motivo          @relation(fields: [motivoId], references: [id], onDelete: Restrict)
  venta               Venta?          @relation(fields: [ventaId], references: [id], onDelete: SetNull)
  compra              Compra?         @relation(fields: [compraId], references: [id], onDelete: SetNull)
  auditoriaStock      AuditoriaStock? @relation(fields: [auditoriaStockId], references: [id], onDelete: SetNull)
  ejecutadoPorUsuario Usuario?        @relation(fields: [ejecutadoPorUsuarioId], references: [id], onDelete: SetNull)

  @@index([varianteId, fecha(sort: Desc)])
  @@index([motivoId])
  @@index([ventaId])
  @@index([compraId])
  @@index([auditoriaStockId])
  @@map("movimiento_stock")
}

// —— Clientes y cuenta corriente ——

model Cliente {
  id                          String    @id @db.Char(6)
  nombre                      String    @db.VarChar(200)
  documento                   String    @db.VarChar(32)
  documentoNormalizado        String    @map("documento_normalizado") @db.VarChar(32)
  correoElectronico           String    @default("") @map("correo_electronico") @db.VarChar(255)
  telefonoPrincipal           String    @default("") @map("telefono_principal") @db.VarChar(32)
  telefonoAlternativo         String    @default("") @map("telefono_alternativo") @db.VarChar(32)
  direccion                   String              @default("") @db.VarChar(500)
  condicionIva                CondicionIvaCliente @default(CONSUMIDOR_FINAL) @map("condicion_iva")
  limiteCompraCuentaCorriente Decimal             @default(0) @map("limite_compra_cuenta_corriente") @db.Decimal(14, 2)
  cuentaCorrienteHabilitada   Boolean   @default(false) @map("cuenta_corriente_habilitada")
  habilitado                  Boolean   @default(true)
  fechaCreacion               DateTime  @default(now()) @map("fecha_creacion") @db.Timestamptz(3)
  fechaActualizacion          DateTime  @updatedAt @map("fecha_actualizacion") @db.Timestamptz(3)
  borrado                     Boolean   @default(false)
  fechaEliminacion            DateTime? @map("fecha_eliminacion") @db.Timestamptz(3)

  ventas                     Venta[]
  movimientosCuentaCorriente MovimientoCuentaCorriente[]
  cuponesDescuento           CuponDescuento[]

  @@index([habilitado])
  @@index([nombre])
  @@index([documento])
  @@index([documentoNormalizado])
  @@index([borrado])
  @@map("cliente")
}

model MovimientoCuentaCorriente {
  id                     String                        @id @db.Char(6)
  clienteId              String                        @map("cliente_id") @db.Char(6)
  ventaId                String?                       @map("venta_id") @db.Char(6)
  fecha                  DateTime                      @default(now()) @db.Timestamptz(3)
  tipoMovimiento         TipoMovimientoCuentaCorriente @map("tipo_movimiento")
  importe                Decimal                       @db.Decimal(14, 2)
  descripcion            String                        @db.VarChar(500)
  auditoriaPagoJson      Json?                         @map("auditoria_pago_json")
  registradoPorUsuarioId String?                       @map("registrado_por_usuario_id") @db.Char(6)
  fechaCreacion          DateTime                      @default(now()) @map("fecha_creacion") @db.Timestamptz(3)

  cliente              Cliente  @relation(fields: [clienteId], references: [id], onDelete: Restrict)
  venta                Venta?   @relation(fields: [ventaId], references: [id], onDelete: SetNull)
  registradoPorUsuario Usuario? @relation("MovimientoCcRegistradoPor", fields: [registradoPorUsuarioId], references: [id], onDelete: SetNull)

  @@index([clienteId, fecha(sort: Desc)])
  @@index([ventaId])
  @@map("movimiento_cuenta_corriente")
}

// —— Proveedores y compras ——

model Proveedor {
  id                        String    @id @db.Char(6)
  nombre                    String    @db.VarChar(200)
  documento                 String    @db.VarChar(32)
  documentoNormalizado      String    @map("documento_normalizado") @db.VarChar(32)
  correoElectronico         String    @default("") @map("correo_electronico") @db.VarChar(255)
  telefonoPrincipal         String    @default("") @map("telefono_principal") @db.VarChar(32)
  telefonoAlternativo       String    @default("") @map("telefono_alternativo") @db.VarChar(32)
  direccion                 String    @default("") @db.VarChar(500)
  limiteCreditoCompras      Decimal   @default(0) @map("limite_credito_compras") @db.Decimal(14, 2)
  comprasCreditoHabilitadas Boolean   @default(false) @map("compras_credito_habilitadas")
  habilitado                Boolean   @default(true)
  fechaCreacion             DateTime  @default(now()) @map("fecha_creacion") @db.Timestamptz(3)
  fechaActualizacion        DateTime  @updatedAt @map("fecha_actualizacion") @db.Timestamptz(3)
  borrado                   Boolean   @default(false)
  fechaEliminacion          DateTime? @map("fecha_eliminacion") @db.Timestamptz(3)

  compras Compra[]
  movimientosCuentaCorrienteProveedor MovimientoCuentaCorrienteProveedor[]

  @@index([habilitado])
  @@index([documento])
  @@index([documentoNormalizado])
  @@index([borrado])
  @@map("proveedor")
}

model Compra {
  id                     String          @id @db.Char(6)
  numero                 String          @unique @db.VarChar(32)
  fecha                  DateTime        @default(now()) @db.Timestamptz(3)
  proveedorId            String          @map("proveedor_id") @db.Char(6)
  nombreProveedorMostrar String          @map("nombre_proveedor_mostrar") @db.VarChar(200)
  condicionCompra        CondicionCompra @map("condicion_compra")
  total                  Decimal         @db.Decimal(14, 2)
  observaciones          String          @default("") @db.VarChar(1000)
  fechaCreacion          DateTime        @default(now()) @map("fecha_creacion") @db.Timestamptz(3)

  proveedor Proveedor     @relation(fields: [proveedorId], references: [id], onDelete: Restrict)
  lineas    CompraLinea[]
  auditoriasStock AuditoriaStock[]
  movimientosStock MovimientoStock[]
  movimientosCuentaCorrienteProveedor MovimientoCuentaCorrienteProveedor[]

  @@index([fecha(sort: Desc)])
  @@index([proveedorId])
  @@map("compra")
}

model CompraLinea {
  id            String  @id @db.Char(6)
  compraId      String  @map("compra_id") @db.Char(6)
  varianteId    String? @map("variante_id") @db.Char(6)
  nombre        String  @db.VarChar(255)
  cantidad      Int
  costoUnitario Decimal @map("costo_unitario") @db.Decimal(14, 2)
  subtotal      Decimal @db.Decimal(14, 2)

  compra   Compra    @relation(fields: [compraId], references: [id], onDelete: Cascade)
  variante Variante? @relation(fields: [varianteId], references: [id], onDelete: SetNull)

  @@index([compraId])
  @@map("compra_linea")
}

model MovimientoCuentaCorrienteProveedor {
  id                     String                        @id @db.Char(6)
  proveedorId            String                        @map("proveedor_id") @db.Char(6)
  compraId               String?                       @map("compra_id") @db.Char(6)
  fecha                  DateTime                      @default(now()) @db.Timestamptz(3)
  tipoMovimiento         TipoMovimientoCuentaCorriente @map("tipo_movimiento")
  importe                Decimal                       @db.Decimal(14, 2)
  descripcion            String                        @db.VarChar(500)
  auditoriaPagoJson      Json?                         @map("auditoria_pago_json")
  registradoPorUsuarioId String?                       @map("registrado_por_usuario_id") @db.Char(6)
  fechaCreacion          DateTime                      @default(now()) @map("fecha_creacion") @db.Timestamptz(3)

  proveedor            Proveedor @relation(fields: [proveedorId], references: [id], onDelete: Restrict)
  compra               Compra?   @relation(fields: [compraId], references: [id], onDelete: SetNull)
  registradoPorUsuario Usuario?  @relation("MovimientoCcProveedorRegistradoPor", fields: [registradoPorUsuarioId], references: [id], onDelete: SetNull)

  @@index([proveedorId, fecha(sort: Desc)])
  @@index([compraId])
  @@map("movimiento_cuenta_corriente_proveedor")
}

// —— Ventas ——

model FormaPago {
  id                 String    @id @db.Char(6)
  codigo             String    @unique @db.VarChar(32)
  nombre             String    @db.VarChar(100)
  facturar           Boolean   @default(true)
  habilitado         Boolean   @default(true)
  orden              Int       @default(0)
  fechaCreacion      DateTime  @default(now()) @map("fecha_creacion") @db.Timestamptz(3)
  fechaActualizacion DateTime  @updatedAt @map("fecha_actualizacion") @db.Timestamptz(3)
  borrado            Boolean   @default(false)
  fechaEliminacion     DateTime? @map("fecha_eliminacion") @db.Timestamptz(3)

  @@index([habilitado, orden])
  @@index([borrado])
  @@map("forma_pago")
}

model EstadoFacturacion {
  id              String   @id @db.Char(6)
  codigo          String   @unique @db.VarChar(32)
  nombre          String   @db.VarChar(64)
  fechaCreacion   DateTime @default(now()) @map("fecha_creacion") @db.Timestamptz(3)

  ventas Venta[]

  @@map("estado_facturacion")
}

model Venta {
  id                      String              @id @db.Char(6)
  numero                  String              @unique @db.VarChar(32)
  fecha                   DateTime            @default(now()) @db.Timestamptz(3)
  clienteId               String?             @map("cliente_id") @db.Char(6)
  nombreClienteMostrar    String              @map("nombre_cliente_mostrar") @db.VarChar(200)
  documentoClienteMostrar String              @default("") @map("documento_cliente_mostrar") @db.VarChar(32)
  condicionIvaCliente     CondicionIvaCliente @default(CONSUMIDOR_FINAL) @map("condicion_iva_cliente")
  formaPago               String              @map("forma_pago") @db.VarChar(32)
  subtotal                Decimal             @db.Decimal(14, 2)
  ajusteMonto             Decimal             @default(0) @map("ajuste_monto") @db.Decimal(14, 2)
  ajustePorcentaje        Decimal?            @map("ajuste_porcentaje") @db.Decimal(5, 2)
  total                   Decimal             @db.Decimal(14, 2)
  facturacion             String              @default("") @db.VarChar(32)
  estadoFacturacionId     String              @map("estado_facturacion_id") @db.Char(6)
  observaciones           String              @default("") @db.VarChar(1000)
  cuponDescuentoId        String?             @unique @map("cupon_descuento_id") @db.Char(6)
  fechaCreacion           DateTime            @default(now()) @map("fecha_creacion") @db.Timestamptz(3)

  cliente           Cliente?          @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  estadoFacturacion EstadoFacturacion @relation(fields: [estadoFacturacionId], references: [id], onDelete: Restrict)
  cuponDescuento    CuponDescuento?   @relation(fields: [cuponDescuentoId], references: [id], onDelete: SetNull)
  lineas            VentaLinea[]
  movimientosStock  MovimientoStock[]
  auditoriasStock   AuditoriaStock[]
  devoluciones      Devolucion[]
  movimientosCuentaCorriente MovimientoCuentaCorriente[]

  @@index([fecha(sort: Desc)])
  @@index([clienteId])
  @@index([estadoFacturacionId])
  @@map("venta")
}

model VentaLinea {
  id             String  @id @db.Char(6)
  ventaId        String  @map("venta_id") @db.Char(6)
  varianteId     String  @map("variante_id") @db.Char(6)
  nombre         String  @db.VarChar(255)
  cantidad       Int
  precioUnitario Decimal @map("precio_unitario") @db.Decimal(14, 2)
  subtotal       Decimal @db.Decimal(14, 2)

  venta    Venta    @relation(fields: [ventaId], references: [id], onDelete: Cascade)
  variante Variante @relation(fields: [varianteId], references: [id], onDelete: Restrict)
  devolucionLineas DevolucionLinea[]

  @@index([ventaId])
  @@map("venta_linea")
}

model Devolucion {
  id                     String   @id @db.Char(6)
  numero                 String   @unique @db.VarChar(32)
  fecha                  DateTime @default(now()) @db.Timestamptz(3)
  ventaId                String   @map("venta_id") @db.Char(6)
  total                  Decimal  @db.Decimal(14, 2)
  observaciones          String   @default("") @db.VarChar(1000)
  registradoPorUsuarioId String?  @map("registrado_por_usuario_id") @db.Char(6)
  fechaCreacion          DateTime @default(now()) @map("fecha_creacion") @db.Timestamptz(3)

  venta                Venta             @relation(fields: [ventaId], references: [id], onDelete: Restrict)
  registradoPorUsuario Usuario?          @relation("DevolucionRegistradaPor", fields: [registradoPorUsuarioId], references: [id], onDelete: SetNull)
  lineas               DevolucionLinea[]
  auditoriasStock      AuditoriaStock[]
  cuponesDescuento     CuponDescuento[]

  @@index([ventaId])
  @@index([fecha(sort: Desc)])
  @@map("devolucion")
}

model DevolucionLinea {
  id             String  @id @db.Char(6)
  devolucionId   String  @map("devolucion_id") @db.Char(6)
  ventaLineaId   String  @map("venta_linea_id") @db.Char(6)
  varianteId     String  @map("variante_id") @db.Char(6)
  nombre         String  @db.VarChar(255)
  cantidad       Int
  precioUnitario Decimal @map("precio_unitario") @db.Decimal(14, 2)
  subtotal       Decimal @db.Decimal(14, 2)

  devolucion Devolucion @relation(fields: [devolucionId], references: [id], onDelete: Cascade)
  ventaLinea VentaLinea @relation(fields: [ventaLineaId], references: [id], onDelete: Restrict)

  @@index([devolucionId])
  @@index([ventaLineaId])
  @@map("devolucion_linea")
}

model CuponDescuento {
  id                      String               @id @db.Char(6)
  numero                  String               @unique @db.VarChar(32)
  /// Código único para escaneo; no se expone en listados de la API.
  codigo                  String               @unique @db.VarChar(32)
  tipoDescuento           TipoDescuentoCupon   @default(porcentaje) @map("tipo_descuento")
  porcentajeDescuento     Decimal?             @map("porcentaje_descuento") @db.Decimal(5, 2)
  montoDescuento          Decimal?             @map("monto_descuento") @db.Decimal(14, 2)
  clienteId               String?              @map("cliente_id") @db.Char(6)
  nombreClienteMostrar      String               @map("nombre_cliente_mostrar") @db.VarChar(200)
  documentoClienteMostrar String               @default("") @map("documento_cliente_mostrar") @db.VarChar(32)
  estado                  EstadoCuponDescuento @default(activo)
  devolucionId            String?              @map("devolucion_id") @db.Char(6)
  observaciones           String               @default("") @db.VarChar(1000)
  registradoPorUsuarioId  String?              @map("registrado_por_usuario_id") @db.Char(6)
  fechaCreacion           DateTime             @default(now()) @map("fecha_creacion") @db.Timestamptz(3)
  fechaVencimiento        DateTime             @map("fecha_vencimiento") @db.Timestamptz(3)

  cliente              Cliente?    @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  devolucion           Devolucion? @relation(fields: [devolucionId], references: [id], onDelete: SetNull)
  registradoPorUsuario Usuario?    @relation("CuponDescuentoRegistradoPor", fields: [registradoPorUsuarioId], references: [id], onDelete: SetNull)
  ventaUsada           Venta?

  @@index([clienteId])
  @@index([devolucionId])
  @@index([estado])
  @@index([fechaCreacion(sort: Desc)])
  @@map("cupon_descuento")
}

// —— Configuración del negocio (fila única) ——

model Negocio {
  id                String   @id @db.Char(6)
  nombre            String   @db.VarChar(200)
  cuit              String   @default("") @db.VarChar(20)
  correoElectronico String   @default("") @map("correo_electronico") @db.VarChar(255)
  telefono          String   @default("") @db.VarChar(32)
  direccion         String   @default("") @db.VarChar(500)
  ciudad            String   @default("") @db.VarChar(120)
  provincia         String   @default("") @db.VarChar(120)
  codigoPostal      String   @default("") @map("codigo_postal") @db.VarChar(16)
  instagram         String   @default("") @db.VarChar(120)
  mostrarInstagram  Boolean  @default(false) @map("mostrar_instagram")
  twitter           String   @default("") @db.VarChar(120)
  mostrarTwitter    Boolean  @default(false) @map("mostrar_twitter")
  tiktok            String   @default("") @db.VarChar(120)
  mostrarTiktok     Boolean  @default(false) @map("mostrar_tiktok")
  temaClaroColorAcento     String   @default("#4a5fd7") @map("tema_claro_color_acento") @db.VarChar(7)
  temaClaroColorFondo      String   @default("#f2f5fa") @map("tema_claro_color_fondo") @db.VarChar(7)
  temaClaroColorSuperficie String   @default("#ffffff") @map("tema_claro_color_superficie") @db.VarChar(7)
  temaClaroColorCabecera   String   @default("#e4eaf4") @map("tema_claro_color_cabecera") @db.VarChar(7)
  temaClaroColorTexto      String   @default("#0f172a") @map("tema_claro_color_texto") @db.VarChar(7)
  temaClaroColorBorde      String   @default("#cbd5e1") @map("tema_claro_color_borde") @db.VarChar(7)
  fechaCreacion     DateTime @default(now()) @map("fecha_creacion") @db.Timestamptz(3)
  fechaActualizacion DateTime @updatedAt @map("fecha_actualizacion") @db.Timestamptz(3)

  @@map("negocio")
}

// —— Parámetros operativos de la tienda (fila única) ——

model ConfiguracionSistema {
  id                         String   @id @db.Char(6)
  maximoCuentaCorriente      Decimal  @default(500000) @map("maximo_cuenta_corriente") @db.Decimal(14, 2)
  porcentajeGananciaSugerida Decimal  @default(35) @map("porcentaje_ganancia_sugerida") @db.Decimal(6, 2)
  diasDeudaCuentaCorriente   Int      @default(30) @map("dias_deuda_cuenta_corriente")
  diasPlazoDevolucion        Int      @default(30) @map("dias_plazo_devolucion")
  stockMinimoAlerta          Int      @default(5) @map("stock_minimo_alerta")
  diasDeshabilitarProductoStockCero Int @default(0) @map("dias_deshabilitar_producto_stock_cero")
  movimientoManualStockHabilitado Boolean @default(true) @map("movimiento_manual_stock_habilitado")
  plantillaCupon                 String   @default("clasica") @map("plantilla_cupon") @db.VarChar(16)
  fechaCreacion              DateTime @default(now()) @map("fecha_creacion") @db.Timestamptz(3)
  fechaActualizacion         DateTime @updatedAt @map("fecha_actualizacion") @db.Timestamptz(3)

  @@map("configuracion_sistema")
}
