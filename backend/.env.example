# Copiar a backend/.env

NODE_ENV=development
HOST=0.0.0.0
PUERTO=3000

# Debe coincidir con docker-compose.yml (raíz del proyecto)
# Puerto = POSTGRES_PORT de .env en la raíz (5433 si 5432 está ocupado en Fedora)
DATABASE_URL=postgresql://erp_dev:cambiar-password-local@localhost:5433/ERPTienda?schema=public

# JWT (mínimo 32 caracteres en producción)
JWT_SECRETO=cambiar-por-secreto-largo-y-aleatorio-en-produccion
JWT_EXPIRES_IN=8h

# CORS: orígenes del frontend separados por coma.
# Desarrollo local:
CORS_ORIGENES=http://localhost:5173,http://127.0.0.1:5173
# Producción (Vercel + VPS): incluir la URL de Vercel, ej.:
# CORS_ORIGENES=https://erp-tienda.vercel.app

# Detrás de nginx/reverse proxy en el VPS (DonWeb)
TRUST_PROXY=false

# Logo del negocio (opcional). Por defecto: ../logo en desarrollo, ./logo en Docker.
# CARPETA_LOGO=/ruta/absoluta/logo

# Rate limit por IP
RATE_LIMIT_LOGIN_MAX=8
RATE_LIMIT_API_MAX=240
RATE_LIMIT_API_WINDOW_MS=60000
