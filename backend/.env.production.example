# Copiar a backend/.env en el VPS (no commitear).
# VPS: 200.58.99.253 — vps-6055529-x.dattaweb.com
# Debe coincidir POSTGRES_USER / POSTGRES_PASSWORD con .env.production de la raíz.

NODE_ENV=production
HOST=127.0.0.1
PUERTO=3000

DATABASE_URL=postgresql://erp:TU_PASSWORD@127.0.0.1:5432/ERPTienda?schema=public

JWT_SECRETO=generar-secreto-aleatorio-de-al-menos-32-caracteres
JWT_EXPIRES_IN=8h

# URL exacta del frontend en Vercel (sin barra final). Varias URLs separadas por coma.
# Obtenerla tras el primer deploy en Vercel (ver DESPLIEGUE-PRIMERA-PRUEBA.md, Fase 2).
CORS_ORIGENES=https://TU-PROYECTO.vercel.app

TRUST_PROXY=true

RATE_LIMIT_LOGIN_MAX=8
RATE_LIMIT_API_MAX=240
RATE_LIMIT_API_WINDOW_MS=60000
