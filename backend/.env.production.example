# Copiar a backend/.env en el VPS (no commitear).
# Un archivo / conjunto de variables por cliente (cada VPS tiene su propia API + PostgreSQL).
# Easypanel: usar nombre del servicio Postgres en la misma red Docker.
# PM2 + Postgres local: 127.0.0.1

NODE_ENV=production
HOST=0.0.0.0
PUERTO=3000

# Easypanel (mismo VPS):
DATABASE_URL=postgresql://erp:TU_PASSWORD@erp-postgres:5432/ERPTienda?schema=public
# PM2 + docker compose local:
# DATABASE_URL=postgresql://erp:TU_PASSWORD@127.0.0.1:5432/ERPTienda?schema=public

JWT_SECRETO=generar-secreto-aleatorio-de-al-menos-32-caracteres
JWT_EXPIRES_IN=8h

# URL exacta del frontend en Cloudflare Pages (sin barra final). Varias URLs separadas por coma.
# Obtenerla tras el primer deploy en Cloudflare (ver DESPLIEGUE.md, sección 10).
CORS_ORIGENES=https://TU-PROYECTO.pages.dev

TRUST_PROXY=true

RATE_LIMIT_LOGIN_MAX=8
RATE_LIMIT_API_MAX=240
RATE_LIMIT_API_WINDOW_MS=60000
